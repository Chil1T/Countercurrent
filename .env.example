# Copy this file to `.env` and fill in real secrets locally.
# Do not commit `.env`.

# OpenAI API key used by `--backend openai`
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini

# OpenAI-compatible gateway or provider
# Example base URLs:
# - provider root URL: https://api.ohmygpt.com
# - version root URL: https://api.ohmygpt.com/v1
# - explicit chat endpoint: https://api.ohmygpt.com/v1/chat/completions
# - explicit responses endpoint: https://openrouter.ai/api/v1/responses
OPENAI_COMPATIBLE_API_KEY=your_openai_compatible_api_key_here
OPENAI_COMPATIBLE_BASE_URL=https://api.ohmygpt.com
OPENAI_COMPATIBLE_MODEL=openai/gpt-4.1-mini

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional stage-specific model routing
MODEL_BLUEPRINT_BUILDER=
MODEL_CURRICULUM_ANCHOR=
MODEL_GAP_FILL=
MODEL_COMPOSE_PACK=
MODEL_REVIEW=
MODEL_CANONICALIZE=

# Hosted backend network timeout in seconds
LLM_TIMEOUT_SECONDS=300
